{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@tradeflow/shared": [
        "./packages/shared/src/index.ts"
      ],
      "@tradeflow/chart-engine": [
        "./packages/chart-engine/src/index.ts"
      ],
      "@tradeflow/market-data": [
        "./packages/market-data/src/index.ts"
      ],
      "@tradeflow/indicators": [
        "./packages/indicators/src/index.ts"
      ],
      "@tradeflow/drawing-engine": [
        "./packages/drawing-engine/src/index.ts"
      ],
      "@tradeflow/interaction-engine": [
        "./packages/interaction-engine/src/index.ts"
      ],
      "@tradeflow/core": [
        "./packages/core/src/index.ts"
      ],
      "@tradeflow/workspace-engine": [
        "./packages/workspace-engine/src/index.ts"
      ],
      "@tradeflow/trading-domain": [
        "./packages/trading-domain/src/index.ts"
      ],
      "@tradeflow/paper-trading": [
        "./packages/paper-trading/src/index.ts"
      ],
      "@tradeflow/risk-engine": [
        "./packages/risk-engine/src/index.ts"
      ],
      "@tradeflow/order-management": [
        "./packages/order-management/src/index.ts"
      ],
      "@tradeflow/execution-engine": [
        "./packages/execution-engine/src/index.ts"
      ],
      "@tradeflow/portfolio-engine": [
        "./packages/portfolio-engine/src/index.ts"
      ],
      "@tradeflow/strategy-engine": [
        "./packages/strategy-engine/src/index.ts"
      ],
      "@tradeflow/backtesting-engine": [
        "./packages/backtesting-engine/src/index.ts"
      ],
      "@tradeflow/optimization-engine": [
        "./packages/optimization-engine/src/index.ts"
      ],
      "@tradeflow/replay-engine": [
        "./packages/replay-engine/src/index.ts"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}
